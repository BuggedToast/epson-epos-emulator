# ─── ePOS Emulator — Configuration ────────────────────────────────────────────
# Copiez ce fichier en .env et adaptez les valeurs.

# Port de l'émulateur ePOS (port 80 requis par Symbioz, nécessite sudo/admin)
EPOS_PORT=80

# Port du dashboard web
DASHBOARD_PORT=8080

# ─── Sauvegarde automatique des tickets ───────────────────────────────────────

# Dossier où enregistrer les tickets (laisser vide pour ne pas sauvegarder)
TICKET_SAVE_PATH=/tmp/tickets

# Activer l'enregistrement automatique à chaque impression (true/false)
TICKET_AUTO_SAVE=false

# Format de sauvegarde :
#   xml  → le corps XML brut reçu (pas de dépendance)
#   pdf  → rendu propre en PDF (nécessite : pip install fpdf2)
TICKET_FORMAT=xml

# ─── Journal persistant ────────────────────────────────────────────────────────
# Rétention du journal des tickets entre les redémarrages :
#   -1 → conservation illimitée
#    0 → pas de persistance (journal effacé à chaque redémarrage)
#    N → conserver uniquement les N derniers jours (ex: 7)
# Le fichier journal (epos_journal.json) est enregistré dans TICKET_SAVE_PATH
# ou, si non défini, dans le même dossier que le script.
LOG_RETENTION_DAYS=-1
